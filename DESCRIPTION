Package: JeffsStatTools
Title: SPSS-Style Descriptive, Frequency, and Regression Tools for Teaching
Version: 0.2.2
Authors@R:
    person("Jeff", "Ackerman", , "SurveyCentre@griffith.edu.au", role = c("aut", "cre"))
Description: Provides SPSS-like descriptive statistics, frequency tables,
    and linear regression output. Functions accept unquoted
    variable names for ease of use and return results invisibly while
    printing user-friendly tables.
License: MIT + file LICENSE
Encoding: UTF-8
Depends:
    R (>= 4.1.0),
    dplyr,
    magrittr,
Roxygen: list(markdown = TRUE)
RoxygenNote: 7.3.3
Imports:
    haven,
    knitr,
    labelled,
    purrr,
    rlang,
    vctrs
